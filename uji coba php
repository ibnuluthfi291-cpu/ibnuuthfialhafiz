<?php
// KONEKSI DATABASE
$conn = mysqli_connect("localhost","root","","db_tugas");

// KALKULATOR
$hasil = "";
if(isset($_POST['hitung'])){
    $a = $_POST['a'];
    $b = $_POST['b'];
    $op = $_POST['op'];

    if($op == "+") $hasil = $a + $b;
    elseif($op == "-") $hasil = $a - $b;
    elseif($op == "*") $hasil = $a * $b;
    elseif($op == "/") $hasil = ($b != 0) ? $a / $b : "Tidak bisa dibagi nol";
}

// LOGIN
$pesan = "";
if(isset($_POST['login'])){
    $user = $_POST['user'];
    $pass = $_POST['pass'];

    if($user == "" || $pass == ""){
        $pesan = "Input tidak lengkap";
    } elseif($user == "admin" && $pass == "123"){
        $pesan = "Login sukses";
    } else {
        $pesan = "Login gagal";
    }
}

// TAMBAH DATA
if(isset($_POST['tambah'])){
    mysqli_query($conn,"INSERT INTO mahasiswa VALUES('', '$_POST[nama]', '$_POST[nim]', '$_POST[jurusan]')");
    header("Location: index.php");
}

// HAPUS DATA
if(isset($_GET['hapus'])){
    mysqli_query($conn,"DELETE FROM mahasiswa WHERE id=$_GET[hapus]");
    header("Location: index.php");
}
?>

