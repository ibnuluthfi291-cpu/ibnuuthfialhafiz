<!DOCTYPE html>
<html>
<head>
    <title>Tugas PHP - Tab</title>
    <style>
        body {
            font-family: Arial;
        }
        .tab {
            overflow: hidden;
            background: #333;
        }
        .tab button {
            background: #333;
            color: white;
            border: none;
            padding: 14px 20px;
            cursor: pointer;
        }
        .tab button:hover {
            background: #555;
        }
        .tabcontent {
            display: none;
            padding: 20px;
        }
        .active {
            display: block;
        }
        .box {
            background: #4a6fb3;
            color: white;
            padding: 15px;
            width: 300px;
        }
    </style>
</head>
<body>

<h2>Semua Tugas dalam Tab</h2>

<div class="tab">
    <button onclick="openTab('t1')">Tugas 1</button>
    <button onclick="openTab('t2')">Tugas 2</button>
    <button onclick="openTab('t3')">Tugas 3</button>
    <button onclick="openTab('t4')">Tugas 4</button>
</div>

<!-- TUGAS 1 -->
<div id="t1" class="tabcontent active">
    <h3>List Hari 1 - 1000</h3>
    <div class="box">
        <ol id="listHari"></ol>
    </div>
</div>

<!-- TUGAS 2 -->
<div id="t2" class="tabcontent">
    <h3>Kalkulator</h3>
    <input type="number" id="a" placeholder="Angka 1"><br><br>
    <input type="number" id="b" placeholder="Angka 2"><br><br>

    <select id="op">
        <option value="+">Tambah</option>
        <option value="-">Kurang</option>
        <option value="*">Kali</option>
        <option value="/">Bagi</option>
    </select><br><br>

    <button onclick="hitung()">Hitung</button>
    <h4 id="hasil"></h4>
</div>

<!-- TUGAS 3 -->
<div id="t3" class="tabcontent">
    <h3>Login</h3>
    <input type="text" id="user" placeholder="Username"><br><br>
    <input type="password" id="pass" placeholder="Password"><br><br>
    <button onclick="login()">Login</button>
    <h4 id="pesan"></h4>
</div>

<!-- TUGAS 4 -->
<div id="t4" class="tabcontent">
    <h3>CRUD (Simulasi)</h3>
    <input type="text" id="nama" placeholder="Nama">
    <input type="text" id="nim" placeholder="NIM">
    <input type="text" id="jurusan" placeholder="Jurusan">
    <button onclick="tambahData()">Tambah</button>

    <table border="1" id="tabel">
        <tr>
            <th>Nama</th>
            <th>NIM</th>
            <th>Jurusan</th>
            <th>Aksi</th>
        </tr>
    </table>
</div>

<script>
/* TAB */
function openTab(id){
    let tab = document.getElementsByClassName("tabcontent");
    for(let i=0; i<tab.length; i++){
        tab[i].style.display = "none";
    }
    document.getElementById(id).style.display = "block";
}

/* TUGAS 1 */
let list = document.getElementById("listHari");
for(let i=1; i<=1000; i++){
    let li = document.createElement("li");
    li.textContent = "Ini adalah hari ke-" + i + " belajar PHP";
    list.appendChild(li);
}

/* TUGAS 2 */
function hitung(){
    let a = parseFloat(document.getElementById("a").value);
    let b = parseFloat(document.getElementById("b").value);
    let op = document.getElementById("op").value;
    let hasil;

    if(op == "+") hasil = a + b;
    else if(op == "-") hasil = a - b;
    else if(op == "*") hasil = a * b;
    else if(op == "/") hasil = b != 0 ? a / b : "Tidak bisa dibagi nol";

    document.getElementById("hasil").innerText = "Hasil: " + hasil;
}

/* TUGAS 3 */
function login(){
    let user = document.getElementById("user").value;
    let pass = document.getElementById("pass").value;

    if(user == "" || pass == ""){
        document.getElementById("pesan").innerText = "Input tidak lengkap";
    } else if(user == "admin" && pass == "123"){
        document.getElementById("pesan").innerText = "Login sukses";
    } else {
        document.getElementById("pesan").innerText = "Login gagal";
    }
}

/* TUGAS 4 (CRUD sederhana) */
function tambahData(){
    let nama = document.getElementById("nama").value;
    let nim = document.getElementById("nim").value;
    let jurusan = document.getElementById("jurusan").value;

    let table = document.getElementById("tabel");
    let row = table.insertRow();

    row.insertCell(0).innerText = nama;
    row.insertCell(1).innerText = nim;
    row.insertCell(2).innerText = jurusan;

    let aksi = row.insertCell(3);
    aksi.innerHTML = "<button onclick='hapus(this)'>Hapus</button>";
}

function hapus(btn){
    let row = btn.parentNode.parentNode;
    row.remove();
}
</script>

</body>
</html>
